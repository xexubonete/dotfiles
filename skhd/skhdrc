# Focus windows
ctrl - j                 : komorebic focus left
ctrl - k                 : komorebic focus up
ctrl - l                 : komorebic focus down
ctrl - 0x29              : komorebic focus right # 0x29 = ñ
ctrl + shift - 0x21      : komorebic cycle-focus previous # 0x21 is [
ctrl + shift - 0x1E      : komorebic cycle-focus next # 0x1E is ]

# Move windows
ctrl + shift - j         : komorebic move left
ctrl + shift - k         : komorebic move up
ctrl + shift - l         : komorebic move down
ctrl + shift - 0x29      : komorebic move right # 0x29 = ñ
ctrl + shift - return    : komorebic promote

# Workspace layer
ctrl + shift - h         : komorebic toggle-workspace-layer

# Resize
ctrl - 0x18              : komorebic resize-axis horizontal increase # 0x18 is +
ctrl - 0x1B              : komorebic resize-axis horizontal decrease # 0x1B is -
ctrl + shift - 0x18      : komorebic resize-axis vertical increase
ctrl + shift - 0x1B      : komorebic resize-axis vertical decrease

# Manipulate windows
ctrl - t                 : komorebic toggle-float
ctrl + shift - t         : komorebic toggle-workspace-float-override
ctrl - f                 : komorebic toggle-monocle
ctrl + shift - f         : komorebic toggle-monocle

# Window manager options
ctrl + shift - r         : komorebic retile
ctrl - p                 : komorebic toggle-pause
ctrl - 0                 : komorebic toggle-window-container-behaviour

# Layouts
ctrl - x                 : komorebic flip-layout horizontal
ctrl - y                 : komorebic flip-layout vertical
ctrl + shift - x         : komorebic session-float-rule

# Workspaces
ctrl - 1                 : komorebic focus-workspace 0
ctrl - 2                 : komorebic focus-workspace 1
ctrl - 3                 : komorebic focus-workspace 2
ctrl - 4                 : komorebic focus-workspace 3
ctrl - 5                 : komorebic focus-workspace 4
ctrl - 6                 : komorebic focus-workspace 5
ctrl - 7                 : komorebic focus-workspace 6
ctrl - 8                 : komorebic focus-workspace 7
ctrl - 9                 : komorebic focus-workspace 8

# Cmd+Q inteligente: si la app frontal tiene varias ventanas, cierra SOLO la
# enfocada (botón rojo de cerrar vía Accessibility); si es la última ventana,
# sale de la app (como el Cmd+Q normal). Así Cmd+Q ya no cierra todo de golpe.
# Debounce con mkdir (atómico): al mantener pulsado, macOS auto-repite la tecla
# y skhd dispararía la acción muchas veces; el candado deja pasar solo una cada
# segundo, así que una pulsación = una acción.
cmd - q                  : g=/tmp/.komo-close-guard; if mkdir "$g" 2>/dev/null; then osascript -e 'tell application "System Events"' -e 'set p to first process whose frontmost is true' -e 'set n to count windows of p' -e 'set bid to bundle identifier of p' -e 'end tell' -e 'if n > 1 then' -e 'tell application "System Events" to tell p to click button 1 of window 1' -e 'else' -e 'tell application id bid to quit' -e 'end if'; ( sleep 1.0; rmdir "$g" ) & fi

# Cerrar SIEMPRE solo la ventana enfocada (sin salir de la app aunque sea la
# última). Alternativa a Cmd+Q para forzar cierre de ventana.
ctrl - q                 : g=/tmp/.komo-closewin-guard; if mkdir "$g" 2>/dev/null; then osascript -e 'tell application "System Events" to tell (first process whose frontmost is true) to click button 1 of window 1'; ( sleep 1.0; rmdir "$g" ) & fi

# Lanzar aplicaciones
# Modificador cmd+ctrl: no lo usa komorebi (que solo usa ctrl y ctrl+shift) ni
# son atajos del sistema (se evitan cmd+ctrl+F/Q/Espacio/D, que sí reserva macOS).
cmd + ctrl - return      : open -na "Ghostty"       # nueva ventana
cmd + ctrl - b           : open -na "Brave Browser" --args --new-window
cmd + ctrl - w           : open -a "WhatsApp"
cmd + ctrl - m           : open -a "Mail"
cmd + ctrl - s           : open -a "Music"          # Música
cmd + ctrl - i           : open -a "Discord"
cmd + ctrl - c           : open -a "Claude"

# Move windows across workspaces
ctrl + shift - 1         : komorebic move-to-workspace 0
ctrl + shift - 2         : komorebic move-to-workspace 1
ctrl + shift - 3         : komorebic move-to-workspace 2
ctrl + shift - 4         : komorebic move-to-workspace 3
ctrl + shift - 5         : komorebic move-to-workspace 4
ctrl + shift - 6         : komorebic move-to-workspace 5
ctrl + shift - 7         : komorebic move-to-workspace 6
ctrl + shift - 8         : komorebic move-to-workspace 7
ctrl + shift - 9         : komorebic move-to-workspace 8