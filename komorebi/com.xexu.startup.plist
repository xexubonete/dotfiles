<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple Computer//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
        <key>Label</key>
        <string>com.xexu.startup</string>
        <key>ProgramArguments</key>
        <array>
                <string>STARTUP_SCRIPT_PLACEHOLDER</string>
        </array>
        <key>RunAtLoad</key>
        <true/>
        <key>KeepAlive</key>
        <false/>
        <key>StandardOutPath</key>
        <string>/tmp/xexu-startup.log</string>
        <key>StandardErrorPath</key>
        <string>/tmp/xexu-startup.err.log</string>
</dict>
</plist>
