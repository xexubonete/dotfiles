{
  "$schema": "https://komorebi-for-mac.lgug2z.com/komorebi.0.1.0.schema.json",
  "app_specific_configuration_path": "$HOME/.config/komorebi/applications.json",
  "cross_monitor_move_behaviour": "Swap",
  "default_workspace_padding": 0,
  "default_container_padding": 0,
  "border": false,
  "border_width": 0,
  "border_offset": 0,
  "border_colours": {
    "single": "#fff700",
    "stack": "#fff700",
    "monocle": "#fff700",
    "unfocused": "#444444"
  },
  "floating_window_aspect_ratio": "Widescreen",
  "floating_layer_behaviour": "Float",
  "resize_delta": 100,
  "ignore_rules": [
    { "kind": "Exe", "id": "Centro de control" },
    { "kind": "Exe", "id": "Control Centre" },
    { "kind": "Exe", "id": "Control Center" },
    { "kind": "Exe", "id": "SystemUIServer" },
    { "kind": "Exe", "id": "Dock" },
    { "kind": "Exe", "id": "Utilidad de Compresión" },
    { "kind": "Exe", "id": "Archive Utility" },
    { "kind": "Exe", "id": "Instalador" },
    { "kind": "Exe", "id": "Installer" },
    { "kind": "Exe", "id": "Información del Sistema" },
    { "kind": "Exe", "id": "System Information" },
    { "kind": "Exe", "id": "Ajustes del Sistema" },
    { "kind": "Exe", "id": "System Settings" }
  ],
  "floating_applications": [],
  "manage_rules": [],
  "monitors": [
    {
      "workspaces": [
        { "name": "1", "layout": "Grid" },
        { "name": "2", "layout": "Grid" },
        { "name": "3", "layout": "Grid" },
        { "name": "4", "layout": "Grid" },
        { "name": "5", "layout": "Grid" }
      ]
    }
  ]
}
